# Backend environment variables
# Copy to .env and fill in values. .env is gitignored.

# Comma-separated frontend origins (required in production)
CORS_ORIGINS=https://acemarketengine.web.app

# development | production
ENVIRONMENT=production

# Firebase Admin SDK: use ONE of these:
# Option A: Path to JSON file (local)
# GOOGLE_APPLICATION_CREDENTIALS=./your-project-firebase-adminsdk-xxxxx.json
# Option B: JSON content as env var (Render, etc.) — paste the full JSON
# FIREBASE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}

# Database — REQUIRED for production (Render, etc.):
#   - Set DATABASE_URL to a PostgreSQL connection string. Render provides this automatically
#     when you add a Postgres database and link it to your web service.
#   - Without DATABASE_URL, SQLite is used (acemarket.db). SQLite on Render is EPHEMERAL:
#     all data (strategies, runs, positions) is wiped on every deploy/restart.
#
# Production (use Render Postgres or any Postgres):
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
#
# Local development (SQLite):
ACEMARKET_DB=acemarket.db

# Optional: INFO, DEBUG, WARNING, ERROR
# LOG_LEVEL=INFO
