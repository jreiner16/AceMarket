# Firebase Admin SDK — path to your service account JSON
GOOGLE_APPLICATION_CREDENTIALS=./your-firebase-adminsdk.json

# PostgreSQL connection string (Supabase session pooler recommended)
DATABASE_URL=postgresql://postgres.your-project-ref:your-password@aws-1-region.pooler.supabase.com:5432/postgres

# CORS origins — comma-separated frontend URLs
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
