# Backend environment variables
# Copy to .env and fill in values. .env is gitignored.

# Comma-separated frontend origins (required in production)
CORS_ORIGINS=https://acemarketengine.web.app

# development | production
ENVIRONMENT=production

# Firebase Admin SDK: use ONE of these:
# Option A: Path to JSON file (local)
# GOOGLE_APPLICATION_CREDENTIALS=./your-project-firebase-adminsdk-xxxxx.json
# Option B: JSON content as env var (Render, etc.) — paste the full JSON
# FIREBASE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}

# SQLite database path (use a persistent volume in production)
ACEMARKET_DB=acemarket.db

# Optional: INFO, DEBUG, WARNING, ERROR
# LOG_LEVEL=INFO
