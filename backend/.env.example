# Optional: load from backend/.env when running uvicorn (values not in env are read from here)

# Database (required in production — SQLite is ephemeral on Render)
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
# ACEMARKET_DB=acemarket.db

# CORS (required in production: comma-separated frontend origins)
# CORS_ORIGINS=https://your-app.web.app,https://your-app.firebaseapp.com

# Environment
# ENVIRONMENT=development
# ENVIRONMENT=production

# Auth: set one of the following. If unset in development, auth is bypassed (dev-user).
# FIREBASE_CREDENTIALS_JSON={"type":"service_account",...}
# FIREBASE_CREDENTIALS_BASE64=<base64-encoded JSON>
# GOOGLE_APPLICATION_CREDENTIALS=path/to/serviceAccountKey.json
# DISABLE_AUTH=1

# Optional
# LOG_LEVEL=INFO
# RISK_FREE_RATE_ANNUAL=0.04
